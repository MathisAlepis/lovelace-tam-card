{
  "name": "tam-card",
  "version": "4.1.0",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=24"
  },
  "description": "Carte Lovelace autonome pour les prochains passages TaM à Montpellier",
  "keywords": [
    "home-assistant",
    "hacs",
    "lovelace",
    "custom-card",
    "montpellier",
    "tam"
  ],
  "module": "dist/tam-card.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/MathisAlepis/lovelace-tam-card.git"
  },
  "bugs": {
    "url": "https://github.com/MathisAlepis/lovelace-tam-card/issues"
  },
  "homepage": "https://github.com/MathisAlepis/lovelace-tam-card#readme",
  "author": "Mathis Alepis",
  "license": "MIT",
  "dependencies": {
    "custom-card-helpers": "2.0.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.11.0",
    "prettier": "^3.9.6",
    "rollup": "^4.62.2",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "start": "rollup -c --watch",
    "build": "yarn clean && yarn rollup",
    "clean": "node scripts/clean.mjs",
    "rollup": "rollup -c",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "yarn lint && yarn format:check && yarn typecheck && yarn test && yarn build",
    "check:api": "node scripts/check-api.mjs",
    "update:route-styles": "node scripts/update-route-styles.mjs",
    "update:route-catalog": "node scripts/update-route-styles.mjs --format json --output route-styles.json"
  }
}
